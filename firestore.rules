rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitives
    function isSignedIn() { return request.auth != null; }
    function isEmailVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function existingData() { return resource.data; }
    function incomingData() { return request.resource.data; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == "nooranwer212@gmail.com" || 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "archivist"
      ); 
    }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // User Validation
    function isValidUser(data) {
      return data.userId == request.auth.uid &&
             data.displayName is string && data.displayName.size() <= 100 &&
             data.email == request.auth.token.email &&
             data.totalPoints is number && data.totalPoints == 0 &&
             data.tomesConquered is number && data.tomesConquered == 0 &&
             data.role == "champion" &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 200000));
    }

    match /users/{userId} {
      allow get: if isValidId(userId);
      allow list: if true;
      allow create: if isOwner(userId) && isValidUser(incomingData());
      allow update: if (isAdmin() && incomingData().userId == existingData().userId) || (
        isOwner(userId) && 
        incomingData().diff(existingData()).affectedKeys().hasOnly(['displayName', 'photoURL', 'bio', 'profileBannerUrl', 'favoriteGenres', 'monthlyGoal', 'badges', 'trophies']) &&
        (!('displayName' in incomingData()) || (incomingData().displayName is string && incomingData().displayName.size() <= 100)) &&
        (!('photoURL' in incomingData()) || (incomingData().photoURL is string && incomingData().photoURL.size() <= 200000)) &&
        (!('bio' in incomingData()) || (incomingData().bio is string && incomingData().bio.size() <= 1000)) &&
        (!('profileBannerUrl' in incomingData()) || (incomingData().profileBannerUrl is string && incomingData().profileBannerUrl.size() <= 1000)) &&
        (!('monthlyGoal' in incomingData()) || (incomingData().monthlyGoal is number && incomingData().monthlyGoal >= 1 && incomingData().monthlyGoal <= 100)) &&
        (!('favoriteGenres' in incomingData()) || (incomingData().favoriteGenres is list && incomingData().favoriteGenres.size() <= 20 && (incomingData().favoriteGenres.size() == 0 || incomingData().favoriteGenres[0] is string))) &&
        (!('badges' in incomingData()) || (incomingData().badges is list && incomingData().badges.size() <= 50)) &&
        (!('trophies' in incomingData()) || (incomingData().trophies is list && incomingData().trophies.size() <= 50))
      );
    }

    // Submission Validation
    function isValidSubmission(data) {
      return data.userId == request.auth.uid &&
             data.userName is string && data.userName.size() <= 100 &&
             data.bookTitle is string && data.bookTitle.size() <= 200 &&
             data.author is string && data.author.size() <= 200 &&
             data.category in ['novel', 'poetry', 'non-fiction'] &&
             data.synopsis is string && data.synopsis.size() <= 2000 &&
             data.assessment is string && data.assessment.size() <= 5000 &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             (!('coverImageUrl' in data) || (data.coverImageUrl is string && data.coverImageUrl.size() <= 2000000)) &&
             data.status == "pending" &&
             data.pointsEarned == 0 &&
             data.createdAt == request.time;
    }

    match /submissions/{submissionId} {
      allow get: if isValidId(submissionId) && resource.data.status == "approved";
      allow get: if isValidId(submissionId) && isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isValidId(submissionId) && isAdmin();

      allow list: if resource.data.status == "approved";
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow list: if isAdmin();
      allow create: if isEmailVerified() && isValidSubmission(incomingData());
      allow update: if (
        isAdmin() && 
        incomingData().status in ['approved', 'rejected'] &&
        incomingData().diff(existingData()).affectedKeys().hasAny(['status', 'pointsEarned', 'impactScore', 'judgeNotes'])
      ) || (
        isOwner(existingData().userId) && existingData().status == "pending" &&
        incomingData().diff(existingData()).affectedKeys().hasOnly(['bookTitle', 'author', 'category', 'synopsis', 'assessment', 'rating', 'coverImageUrl', 'updatedAt']) &&
        incomingData().status == "pending"
      );
      allow delete: if isAdmin() || (isOwner(existingData().userId) && existingData().status == "pending");
    }

    match /config/league_rules {
      allow read: if true;
      allow write: if isAdmin() && 
                   incomingData().content is string && 
                   incomingData().content.size() <= 10000 &&
                   incomingData().lastUpdated == request.time;
    }

    match /stats/global {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /rules_audit/{auditId} {
      allow read: if isAdmin();
      allow create: if isAdmin() && 
                    incomingData().timestamp == request.time &&
                    incomingData().archivistId == request.auth.uid &&
                    incomingData().configPath is string;
    }
  }
}
